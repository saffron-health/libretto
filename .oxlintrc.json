{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "options": {
    "typeAware": true
  },
  "plugins": ["typescript"],
  "jsPlugins": ["./oxlint-plugin-libretto.mjs"],
  "categories": {
    "correctness": "off",
    "suspicious": "off",
    "pedantic": "off",
    "perf": "off",
    "style": "off",
    "restriction": "off",
    "nursery": "off"
  },
  "rules": {
    "typescript/no-floating-promises": "error",
    "typescript/await-thenable": "error",
    "libretto/no-await-import": "error",
    "libretto/require-disable-description": "error"
  },
  "ignorePatterns": [
    "**/dist/**",
    "docs/**",
    ".opencode/**",
    "**/*.gen.ts",
    "**/*.config.ts",
    "packages/create-libretto/**",
    "packages/browser-tools/evals/**",
    "apps/website/src/**/*.spec.ts",
    "apps/website/src/**/*.spec.tsx"
  ]
}
