#!/usr/bin/env bash
set -euo pipefail

node_version="22.23.1"
case "$(uname -m)" in
	x86_64) node_arch="x64" ;;
	aarch64) node_arch="arm64" ;;
	*)
		echo "Unsupported architecture: $(uname -m)" >&2
		exit 1
		;;
esac

node_name="node-v${node_version}-linux-${node_arch}"
node_root="$HOME/.local/share/node/$node_name"

if [[ ! -x "$node_root/bin/node" ]]; then
	echo "Installing Node.js $node_version..."
	tmp_dir="$(mktemp -d)"
	trap 'rm -rf "$tmp_dir"' EXIT
	curl -fsSLo "$tmp_dir/$node_name.tar.xz" \
		"https://nodejs.org/dist/v${node_version}/$node_name.tar.xz"
	curl -fsSLo "$tmp_dir/SHASUMS256.txt" \
		"https://nodejs.org/dist/v${node_version}/SHASUMS256.txt"
	(
		cd "$tmp_dir"
		grep "  $node_name.tar.xz$" SHASUMS256.txt | sha256sum --check --strict -
	)
	mkdir -p "$(dirname "$node_root")"
	tar -xJf "$tmp_dir/$node_name.tar.xz" -C "$(dirname "$node_root")"
fi

mkdir -p "$HOME/.local/bin"
for executable in node npm npx corepack; do
	ln -sfn "$node_root/bin/$executable" "$HOME/.local/bin/$executable"
done
hash -r

echo "Using Node.js $(node --version)."
corepack enable --install-directory "$HOME/.local/bin"
pnpm install --frozen-lockfile
pnpm exec playwright install chromium

if ! command -v ntn >/dev/null 2>&1; then
	echo "Installing Notion CLI..."
	ntn_installer="$(mktemp)"
	curl -fsSLo "$ntn_installer" https://ntn.dev
	NTN_INSTALL_DIR="$HOME/.local/bin" bash "$ntn_installer"
	rm -f "$ntn_installer"
fi

if [[ ! -f "$HOME/.agents/skills/notion-cli/SKILL.md" ]]; then
	echo "Installing the Notion CLI skill for Amp..."
	npx --yes skills add makenotion/skills \
		--skill notion-cli \
		--global \
		--agent amp \
		--yes
fi

if ! command -v vercel >/dev/null 2>&1; then
	echo "Installing Vercel CLI..."
	npm install --global --prefix "$HOME/.local" vercel
fi
