{
  "name": "libretto-playwright-debug",
  "version": "0.1.0",
  "description": "Open GitHub autofix pull requests from failed Playwright runs",
  "license": "MIT",
  "homepage": "https://libretto.sh",
  "repository": {
    "type": "git",
    "url": "https://github.com/saffron-health/libretto",
    "directory": "packages/playwright-debug"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:vitest": "vitest run",
    "prepack": "pnpm run build"
  },
  "peerDependencies": {
    "playwright": "^1.58.2"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.81",
    "@ai-sdk/openai": "3.0.66",
    "libretto-browser-tools": "workspace:*",
    "ai": "6.0.140",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "playwright": "^1.58.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
