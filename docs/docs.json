{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Libretto",
  "description": "Toolkit for building, debugging, and maintaining browser automations.",
  "colors": {
    "primary": "#12ce41",
    "light": "#2fdb4f",
    "dark": "#12ce41"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logos/logo-light.svg",
    "dark": "/logos/logo-dark.svg",
    "href": "https://libretto.sh"
  },
  "fonts": {
    "heading": {
      "family": "Fraunces",
      "format": "woff2",
      "weight": 300
    },
    "body": {
      "family": "Commit Mono",
      "source": "/fonts/CommitMono-VF.woff2",
      "format": "woff2",
      "weight": 400
    }
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "background": {
    "color": {
      "light": "#111111",
      "dark": "#111111"
    }
  },
  "styling": {
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark"
      }
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "get-started/quickstart",
              "get-started/first-workflow",
              "get-started/deploying"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/one-shot-workflow-generation",
              "guides/interactive-workflow-building",
              "guides/debugging-workflows",
              "guides/convert-to-network-requests"
            ]
          },
          {
            "group": "Understand Libretto",
            "pages": [
              "understand-libretto/core-concepts",
              "understand-libretto/how-workflow-generation-works",
              "understand-libretto/configuration",
              "understand-libretto/automation-and-bot-detection",
              "understand-libretto/website-authentication",
              "understand-libretto/error-handling-and-recovery",
              "understand-libretto/autofix-debugging"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "CLI",
            "pages": [
              "reference/cli/open-and-connect",
              "reference/cli/sessions",
              "reference/cli/profiles",
              "reference/cli/snapshot",
              "reference/cli/exec",
              "reference/cli/run-and-resume",
              "reference/cli/session-logs",
              "reference/cli/pages",
              "reference/cli/share"
            ]
          },
          {
            "group": "Runtime",
            "pages": [
              "reference/runtime/workflow",
              "reference/runtime/authentication",
              "reference/runtime/network-requests",
              "reference/runtime/file-downloads",
              "reference/runtime/page-fallbacks",
              "reference/runtime/playwright-debugger"
            ]
          }
        ]
      },
      {
        "tab": "Hosting",
        "groups": [
          {
            "group": "Libretto Cloud Hosting",
            "pages": [
              "libretto-cloud-hosting/overview",
              "libretto-cloud-hosting/authentication",
              "libretto-cloud-hosting/deployments",
              "libretto-cloud-hosting/observability-and-debugging",
              "libretto-cloud-hosting/billing",
              "libretto-cloud-hosting/stealth",
              "libretto-cloud-hosting/website-authentication"
            ]
          },
          {
            "group": "Alternative providers",
            "pages": [
              "alternative-providers/overview",
              "alternative-providers/kernel",
              "alternative-providers/browserbase",
              "alternative-providers/steel",
              "alternative-providers/gcp",
              "alternative-providers/aws"
            ]
          },
          {
            "group": "Libretto Cloud API",
            "pages": [
              "libretto-cloud-api/overview",
              "libretto-cloud-api/sessions",
              "libretto-cloud-api/recordings",
              "libretto-cloud-api/deployments-and-workflows",
              "libretto-cloud-api/jobs-and-logs",
              "libretto-cloud-api/credentials",
              "libretto-cloud-api/webhooks",
              "libretto-cloud-api/schedules"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/saffron-health/libretto",
          "icon": "github"
        },
        {
          "anchor": "npm",
          "href": "https://www.npmjs.com/package/libretto",
          "icon": "npm"
        },
        {
          "anchor": "Changelog",
          "href": "https://github.com/saffron-health/libretto/releases",
          "icon": "clock-rotate-left"
        },
        {
          "anchor": "Discord",
          "href": "https://discord.gg/NYrG56hVDt",
          "icon": "discord"
        },
        {
          "anchor": "Talk to a dev",
          "href": "https://cal.com/team/libretto/demo",
          "icon": "video"
        }
      ]
    }
  },
  "navbar": {},
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/saffron-health/libretto",
      "discord": "https://discord.gg/NYrG56hVDt",
      "linkedin": "https://www.linkedin.com/company/saffron-health"
    }
  },
  "integrations": {
    "fathom": {
      "siteId": "OSJVKIKF"
    }
  }
}
