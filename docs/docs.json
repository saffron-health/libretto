{
  "$schema": "https://holocron.so/docs.json",
  "name": "Libretto",
  "description": "Toolkit for building, debugging, and maintaining browser automations.",
  "colors": {
    "primary": "#12ce41",
    "light": "#12ce41",
    "dark": "#067a22"
  },
  "icons": { "library": "fontawesome" },
  "favicon": {
    "light": "/docs/brand-kit/logos/libretto-icosahedron-light.svg",
    "dark": "/docs/brand-kit/logos/libretto-icosahedron-dark.svg"
  },
  "logo": {
    "light": "/docs/logos/logo-light.svg",
    "dark": "/docs/logos/logo-dark.svg",
    "href": "https://libretto.sh",
    "text": "Libretto"
  },
  "fonts": {
    "fontSize": 15,
    "heading": {
      "family": "Fraunces",
      "format": "woff2",
      "weight": 300
    }
  },
  "layout": {
    "maxWidth": 1200,
    "sidebarWidth": 240,
    "columnGap": 32,
    "radius": 6
  },
  "decorativeLines": "none",
  "appearance": {
    "default": "system"
  },
  "background": {
    "color": {
      "dark": "#111111"
    }
