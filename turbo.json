{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "outputLogs": "errors-only"
    },
    "type-check": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "test:vitest": {
      "dependsOn": ["build"],
      "cache": false,
      "outputLogs": "errors-only"
    },
    "benchmarks": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "evals": {
      "dependsOn": ["^build"],
      "cache": false,
      "env": [
        "ANTHROPIC_API_KEY",
        "GCLOUD_PROJECT",
        "GOOGLE_API_KEY",
        "GOOGLE_APPLICATION_CREDENTIALS",
        "GOOGLE_CLOUD_LOCATION",
        "GOOGLE_CLOUD_PROJECT",
        "GOOGLE_GENERATIVE_AI_API_KEY",
        "LIBRETTO_EVAL_MODEL",
        "LIBRETTO_EVAL_VERBOSE",
        "OPENAI_API_KEY"
      ]
    }
  }
}
