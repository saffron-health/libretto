{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "outputLogs": "errors-only"
    },
    "type-check": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "test:vitest": {
      "dependsOn": ["build"],
      "cache": false,
      "outputLogs": "errors-only"
    },
    "benchmarks": {
      "dependsOn": ["build", "^build"],
      "cache": false,
      "env": [
        "BROWSERBASE_API_KEY",
        "BROWSERBASE_ENDPOINT",
        "BROWSERBASE_PROJECT_ID",
        "BROWSER_USE_API_KEY",
        "BROWSER_USE_BASE_URL",
        "KERNEL_API_ENDPOINT",
        "KERNEL_API_KEY",
        "KERNEL_ENDPOINT",
        "KERNEL_PROXY_ID",
        "KERNEL_TIMEOUT_SECONDS",
        "OPENAI_API_KEY",
        "STEEL_API_KEY",
        "STEEL_BASE_URL",
        "STEEL_CONNECT_URL"
      ]
    },
    "evals": {
      "dependsOn": ["^build"],
      "cache": false,
      "env": [
        "ANTHROPIC_API_KEY",
        "GCLOUD_PROJECT",
        "GOOGLE_API_KEY",
        "GOOGLE_APPLICATION_CREDENTIALS",
        "GOOGLE_CLOUD_LOCATION",
        "GOOGLE_CLOUD_PROJECT",
        "GOOGLE_GENERATIVE_AI_API_KEY",
        "OPENAI_API_KEY"
      ]
    }
  }
}
