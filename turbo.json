{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "outputLogs": "errors-only"
    },
    "type-check": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "lint": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/.lintcn/**/*.go",
        "$TURBO_ROOT$/.lintcn/**/*.json"
      ],
      "outputs": []
    },
    "test:vitest": {
      "dependsOn": ["build"],
      "cache": false,
      "outputLogs": "errors-only"
    },
    "benchmarks": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "evals": {
      "dependsOn": ["^build"],
      "cache": false
    }
  }
}
